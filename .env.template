# Allure Server — Environment Variables
# Copy to .env and fill in values: devbox run env:init

# Database (used by allure-server + postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=allure
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/allure
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_DATABASE=postgresql
SPRING_JPA_HIBERNATE_DDL-AUTO=update

# TMS (YouTrack)
TMS_ENABLED=false
TMS_HOST=jira.localhost
TMS_TOKEN=<token-here>
TMS_DRYRUN=false

# Datadog
DATADOG_ENABLED=true
DATADOG_HOST=datadog-agent
DATADOG_PREFIX=voxsmart.allure
DD_API_KEY=<your-dd-api-key>
DD_SITE=datadoghq.eu
